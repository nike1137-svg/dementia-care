{
  "_comment": "새록이 문항 은행 — 1주차(지남력). 이 파일은 서버(FastAPI)가 읽어 DB에 seed하는 원본이다. answer 필드는 절대 프런트로 내려보내지 않는다.",
  "version": "1.0",
  "created": "2026-07-18",
  "week": 1,
  "domain": "지남력",
  "app_name": "새록이",
  "tone": "친근한 존대 (~이에요/~예요). 명령형 금지. 재촉 금지.",

  "answer_types": {
    "static": "정답이 고정. answer 필드에 정답 문자열.",
    "dynamic": "정답이 오늘 날짜에 따라 바뀜. 서버가 answer_rule로 보기와 정답을 생성. DB에 정답을 저장할 수 없음."
  },

  "levels": {
    "1": "2택. 답이 뻔한 보기. 실패 경험 방지가 목적.",
    "2": "4택 + 단서. 기본 난이도.",
    "3": "4택, 단서 없음, 헷갈리는 보기. 타이핑 없음(어르신 제약)."
  },

  "common": {
    "mood": {
      "prompt": "안녕하세요, 새록이예요. 오늘 기분은 어떠세요?",
      "choices": ["좋아요", "그저 그래요", "별로예요"],
      "judged": false,
      "_note": "첫 방문이 아니면 prompt를 '오늘 기분은 어떠세요?'로 짧게 해도 된다. 판정하지 않는다."
    },

    "warmup": {
      "_note": "매일 동일한 로직. 전부 dynamic — 서버가 오늘 날짜로 보기와 정답을 만든다.",
      "1": {
        "id": 1111,
        "prompt": "오늘은 평일이에요, 주말이에요?",
        "answer_type": "dynamic",
        "answer_rule": "weekday_type",
        "choices_rule": "fixed:['평일','주말']"
      },
      "2": {
        "id": 1112,
        "prompt": "오늘은 무슨 요일이에요?",
        "answer_type": "dynamic",
        "answer_rule": "weekday",
        "choices_rule": "weekday_4 (정답 + 인접 요일 3개, 순서 섞기)"
      },
      "3": {
        "id": 1113,
        "prompt": "오늘은 몇 월 며칠이에요?",
        "answer_type": "dynamic",
        "answer_rule": "month_day",
        "choices_rule": "date_4 (정답 + 앞뒤 며칠 3개, 순서 섞기)"
      }
    },

    "messages": {
      "correct": "맞아요, 잘하셨어요!",
      "wrong_first": "비슷해요, 하나만 더 생각해볼까요?",
      "wrong_second": "괜찮아요, 오늘은 여기까지도 잘하셨어요",
      "_forbidden": ["틀렸습니다", "오답입니다", "다시 하세요", "정답은 ~입니다"],
      "_note": "2차 오답에서도 정답을 알려주지 않는다. PRD §3.4."
    }
